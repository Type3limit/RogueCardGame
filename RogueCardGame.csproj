<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>RogueCardGame</RootNamespace>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="GodotSharp" Version="4.3.0" />
  </ItemGroup>

  <!-- 
    NOTE: When building inside Godot editor, switch SDK back to:
    <Project Sdk="Godot.NET.Sdk/4.3.0">
    and remove the GodotSharp PackageReference.
    The standard SDK is used here for standalone C# compilation.
  -->
</Project>
